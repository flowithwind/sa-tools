# ============================================
# SA-Tools 环境变量配置示例
# SA-Tools Environment Variables Example
# ============================================

# 复制此文件为 .env.local（本地开发）或 .env（生产环境）
# Copy this file to .env.local (development) or .env (production)

# ============================================
# 阿里云通义千问 API 配置 (必填)
# Alibaba Cloud Tongyi API Configuration (Required)
# ============================================

# 通义千问 API 密钥
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ============================================
# 火山引擎配置 (可选，用于豆包模型)
# Volcano Engine Configuration (Optional, for Doubao models)
# ============================================

# 火山引擎 API 密钥
VOLCANO_ENGINE_API_KEY=your_volcano_api_key_here

# 火山引擎端点 ID
# 在火山引擎控制台创建推理接入点后获取
VOLCANO_ENGINE_ENDPOINT_ID=your_endpoint_id_here

# ============================================
# 阿里云 OSS 配置 (必填，用于文件上传)
# Alibaba Cloud OSS Configuration (Required, for file upload)
# ============================================

# 阿里云 AccessKey ID
# 获取地址：https://ram.console.aliyun.com/manage/ak
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id_here

# 阿里云 AccessKey Secret
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret_here

# OSS 存储桶名称
OSS_BUCKET=your_bucket_name

# OSS 区域（如 oss-cn-hangzhou、oss-cn-shanghai 等）
OSS_REGION=oss-cn-hangzhou

# OSS 端点 URL
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ============================================
# 可选配置
# Optional Configuration
# ============================================

# Next.js 环境
NODE_ENV=development

# DashScope API 基础 URL（通常不需要修改）
# NEXT_PUBLIC_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
